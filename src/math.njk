{% block mobile_nav %}
    <a href="#basic">📘 基础</a>
    <a href="#intermediate">📙 进阶</a>
    <a href="#advanced">📕 高难</a>
{% endblock %}

{% block content %}
    <!-- 基础部分 -->
    <section id="basic" class="subject-section">
        <div class="section-title">📘 基础</div>
        <div class="section-desc">代数、几何、初等函数 · 夯实根基</div>
        <div class="doc-grid">
            <div class="doc-card">
                <div class="doc-card-content">
                    <h3>初等数学公式手册.pdf</h3>
                    <p>涵盖代数、三角、几何基础公式，适合快速查阅。</p>
                    <a href="/docs/elementary_math.pdf" target="_blank" class="doc-btn">在线预览</a>
                </div>
            </div>
            <div class="doc-card">
                <div class="doc-card-content">
                    <h3>函数与图像详解.pdf</h3>
                    <p>一次函数、二次函数、指数对数函数图像性质分析。</p>
                    <a href="/docs/functions.pdf" target="_blank" class="doc-btn">在线预览</a>
                </div>
            </div>
            <div class="doc-card">
                <div class="doc-card-content">
                    <h3>立体几何入门.pdf</h3>
                    <p>点线面位置关系、空间向量初步，配有例题。</p>
                    <a href="/docs/geometry_basic.pdf" target="_blank" class="doc-btn">在线预览</a>
                </div>
            </div>
        </div>
    </section>

    <!-- 进阶部分 -->
    <section id="intermediate" class="subject-section">
        <div class="section-title">📙 进阶</div>
        <div class="section-desc">微积分、线性代数、概率统计 · 能力提升</div>
        <div class="doc-grid">
            <div class="doc-card">
                <div class="doc-card-content">
                    <h3>微积分核心笔记.pdf</h3>
                    <p>极限、导数、积分，包含重要定理与经典例题。公式示例：{% raw %}\[ \int_{0}^{1} x^2 dx = \frac{1}{3} \]{% endraw %}</p>
                    <a href="/docs/calculus_notes.pdf" target="_blank" class="doc-btn">在线预览</a>
                </div>
            </div>
            <div class="doc-card">
                <div class="doc-card-content">
                    <h3>线性代数精讲.pdf</h3>
                    <p>矩阵、行列式、特征值，结合几何意义讲解。</p>
                    <a href="/docs/linear_algebra.pdf" target="_blank" class="doc-btn">在线预览</a>
                </div>
            </div>
            <div class="doc-card">
                <div class="doc-card-content">
                    <h3>概率论与数理统计.pdf</h3>
                    <p>随机变量、分布函数、参数估计，实例丰富。</p>
                    <a href="/docs/probability.pdf" target="_blank" class="doc-btn">在线预览</a>
                </div>
            </div>
        </div>
    </section>

    <!-- 高难部分 -->
    <section id="advanced" class="subject-section">
        <div class="section-title">📕 高难</div>
        <div class="section-desc">实分析、泛函、拓扑 · 深度拓展</div>
        <div class="doc-grid">
            <div class="doc-card">
                <div class="doc-card-content">
                    <h3>实分析基础.pdf</h3>
                    <p>测度论、勒贝格积分，适合高年级本科生及研究生。</p>
                    <a href="/docs/real_analysis.pdf" target="_blank" class="doc-btn">在线预览</a>
                </div>
            </div>
            <div class="doc-card">
                <div class="doc-card-content">
                    <h3>泛函分析导论.pdf</h3>
                    <p>赋范空间、线性算子、谱理论初步。</p>
                    <a href="/docs/functional_analysis.pdf" target="_blank" class="doc-btn">在线预览</a>
                </div>
            </div>
            <div class="doc-card">
                <div class="doc-card-content">
                    <h3>拓扑学基础.pdf</h3>
                    <p>点集拓扑、同伦论简介，抽象思维训练。</p>
                    <a href="/docs/topology.pdf" target="_blank" class="doc-btn">在线预览</a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}