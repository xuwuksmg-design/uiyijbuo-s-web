<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>{{ title or "我的资源库" }}</title>

<!-- KaTeX 支持 -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.css">
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/contrib/auto-render.min.js"
        onload="renderMathInElement(document.body, { 
            delimiters: [
                {left: '\\[', right: '\\]', display: true},
                {left: '\\(', right: '\\)', display: false}
            ]
        });"></script>

<!-- 全局 CSS 变量 -->
{% include "variables.njk" %}

<!-- 公共样式 -->
{% include "css/global.njk" %}

<!-- 桌面端专用样式 -->
{% include "css/desktop.njk" %}

<!-- 移动端专用样式 -->
{% include "css/mobile.njk" %}

{% include "variables.njk" %}

<!-- 公共脚本：KaTeX 加载检测 + 加载器隐藏 + 主题切换 -->
<script>
    // 立即设置主题（同步执行，在页面渲染前）
    (function() {
        let theme = localStorage.getItem('site-theme');
        if (!theme) {
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            theme = prefersDark ? 'dark' : 'light';
        }
        if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
        } else {
            document.documentElement.removeAttribute('data-theme');
        }
    })();

    // 隐藏加载界面并彻底移除元素
    let loaderHidden = false;
    function hideLoader() {
        if (loaderHidden) return;
        const loader = document.getElementById('loader');
        if (!loader) return;

        loaderHidden = true;
        loader.style.opacity = '0';

        // 监听过渡结束，移除元素（彻底清除）
        const onTransitionEnd = () => {
            if (loader.parentNode) {
                loader.removeEventListener('transitionend', onTransitionEnd);
                loader.remove();  // 直接移除元素，不留残留
            }
        };
        loader.addEventListener('transitionend', onTransitionEnd);

        // 后备：如果过渡事件未触发（例如元素被隐藏或浏览器不支持），300ms后强制移除
        setTimeout(() => {
            if (loader.parentNode) {
                loader.removeEventListener('transitionend', onTransitionEnd);
                loader.remove();
            }
        }, 300);
    }

    // 后备：如果页面加载超时（3秒），自动隐藏加载界面
    let timeoutId = setTimeout(hideLoader, 3000);

    window.addEventListener('load', function() {
        // 清除后备超时
        clearTimeout(timeoutId);

        // KaTeX 加载检测
        var status = {
            katex: typeof katex !== 'undefined',
            renderMathInElement: typeof renderMathInElement !== 'undefined'
        };
        console.log('🔍 KaTeX 加载状态:', status);
        if (!status.katex || !status.renderMathInElement) {
            var msg = '❌ 数学公式加载失败！请检查网络后刷新页面。';
            alert(msg);
            var warning = document.createElement('div');
            warning.style.backgroundColor = '#ffebee';
            warning.style.color = '#c62828';
            warning.style.padding = '12px 16px';
            warning.style.margin = '0 auto 16px auto';
            warning.style.borderRadius = '8px';
            warning.style.textAlign = 'center';
            warning.style.fontSize = '14px';
            warning.style.maxWidth = '800px';
            warning.innerHTML = msg;
            var container = document.querySelector('.container');
            if (container && container.firstChild) {
                container.insertBefore(warning, container.firstChild);
            }
        }

        // 正常加载完成后隐藏加载界面
        hideLoader();
    });

    // 主题切换按钮绑定
    document.addEventListener('DOMContentLoaded', function() {
        const toggleBtn = document.getElementById('theme-toggle');
        if (!toggleBtn) return;

        function applyTheme(theme) {
            const html = document.documentElement;
            if (theme === 'dark') {
                html.setAttribute('data-theme', 'dark');
            } else {
                html.removeAttribute('data-theme');
            }
            localStorage.setItem('site-theme', theme);
        }

        function toggleTheme() {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            applyTheme(isDark ? 'light' : 'dark');
        }

        toggleBtn.addEventListener('click', toggleTheme);
    });
</script>
