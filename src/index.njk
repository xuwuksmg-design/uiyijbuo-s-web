---
title: 资源库 | 导航
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    {% include "head.njk" %}
</head>
<body>
    {% include "header.njk" %}

    <div class="container">
        <!-- 主页左右分栏布局 -->
        <div class="home-layout">
            <!-- 左半部分：时间与网站寄语 -->
            <div class="home-left">
                <!-- 时间显示器 -->
                <div class="time-card">
                    <div class="time-header">Beijing Time</div>
                    <div class="time-clock" id="bj-clock">00:00:00</div>
                    <div class="time-date" id="bj-date">时间加载中...</div>
                </div>

                <!-- 网站寄语 -->
                <div class="message-card">
                    <p>愿你我向往的未来，<br>已经在某个世界实现。</p>
                </div>
            </div>

            <!-- 右半部分：名言与学科入口 -->
            <div class="home-right">
                <!-- 上半部分：名人名言 -->
                <div class="quote-card">
                    <p>“学问是异常珍贵的东西，从任何源泉吸收都不可耻。”</p>
                    <span class="quote-author">—— 托马斯·阿奎那</span>
                </div>

                <!-- 下半部分：六个学科入口 -->
                <div class="subject-grid">
                    <a href="/chinese/" class="subject-card">
                        <div class="subject-icon">📖</div>
                        <h3>语文</h3>
                        <p>古诗文、现代文、写作素材</p>
                    </a>
                    <a href="/math/" class="subject-card">
                        <div class="subject-icon">📐</div>
                        <h3>数学</h3>
                        <p>公式推导、真题解析、竞赛资料</p>
                    </a>
                    <a href="/english/" class="subject-card">
                        <div class="subject-icon">🌍</div>
                        <h3>英语</h3>
                        <p>词汇、语法、听力、阅读</p>
                    </a>
                    <a href="/physics/" class="subject-card">
                        <div class="subject-icon">⚛️</div>
                        <h3>物理</h3>
                        <p>力学、电磁学、热学、近代物理</p>
                    </a>
                    <a href="/chemistry/" class="subject-card">
                        <div class="subject-icon">🧪</div>
                        <h3>化学</h3>
                        <p>有机、无机、实验、工业流程</p>
                    </a>
                    <a href="/biology/" class="subject-card">
                        <div class="subject-icon">🧬</div>
                        <h3>生物</h3>
                        <p>分子与细胞、遗传、生态</p>
                    </a>
                </div>
            </div>
        </div>

        {% include "footer.njk" %}
    </div>
    <!-- 专属主页的北京时间采集脚本 -->
    <script>
        function updateBeijingTime() {
            const now = new Date();
            // 先转换为世界标准时间 (UTC)，再精准加上东八区(北京)的偏移量
            const utc = now.getTime() + (now.getTimezoneOffset() * 60000);
            const bjDate = new Date(utc + (3600000 * 8));

            // 格式化时间
            const h = String(bjDate.getHours()).padStart(2, '0');
            const m = String(bjDate.getMinutes()).padStart(2, '0');
            const s = String(bjDate.getSeconds()).padStart(2, '0');

            const year = bjDate.getFullYear();
            const month = String(bjDate.getMonth() + 1).padStart(2, '0');
            const day = String(bjDate.getDate()).padStart(2, '0');
            const weekDays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
            const weekDay = weekDays[bjDate.getDay()];

            const clockEl = document.getElementById('bj-clock');
            const dateEl = document.getElementById('bj-date');

            if(clockEl) clockEl.textContent = `${h}:${m}:${s}`;
            if(dateEl) dateEl.textContent = `${year}年${month}月${day}日 ${weekDay}`;
        }

        // 启动时间齿轮
        setInterval(updateBeijingTime, 1000);
        updateBeijingTime(); // 立即显化一次
    </script>
</body>
</html>