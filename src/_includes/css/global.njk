<style>
    /* ========= 基础重置 ========= */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    body {
        font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        line-height: 1.5;
        padding: 2rem 1rem;
        transition: background 0.3s ease, color 0.2s ease;
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
    }

    /* ========= 导航栏（通用） ========= */
    .nav-bar {
        margin-bottom: 2rem;
        text-align: right;
    }
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--accent-primary);
        color: white;
        padding: 0.6rem 1.2rem;
        border-radius: 2rem;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px var(--shadow);
    }
    .back-link:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 4px 8px var(--shadow);
    }
    .theme-toggle {
        background: var(--accent-primary);
        border: none;
        color: white;
        font-size: 1.2rem;
        padding: 0.6rem 1rem;
        border-radius: 2rem;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px var(--shadow);
        margin-left: 0.5rem;
    }
    .theme-toggle:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 4px 8px var(--shadow);
    }

    /* ========= 通用标题 ========= */
    .section-title {
        font-size: 1.75rem;
        font-weight: 600;
        margin: 1rem 0 1.5rem 0;
        border-left: 4px solid var(--accent-primary);
        padding-left: 1rem;
    }

    /* ========= 页脚 ========= */
    footer {
        text-align: center;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
        color: var(--text-secondary);
        font-size: 0.875rem;
    }

    /* ========= 搜索框 ========= */
    .search-container {
        margin: 1rem 0 2rem 0;
    }
    .search-box {
        width: 100%;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 2rem;
        color: var(--text-primary);
        outline: none;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px var(--shadow);
    }
    .search-box:focus {
        border-color: var(--accent-primary);
        box-shadow: 0 0 0 3px rgba(var(--accent-primary-rgb, 37, 99, 235), 0.2);
    }
    .search-box::placeholder {
        color: var(--text-secondary);
        opacity: 0.7;
    }
    mark {
        background: rgba(37, 99, 235, 0.2);
        color: inherit;
        border-radius: 0.2rem;
        padding: 0 0.1rem;
    }
    [data-theme="dark"] mark {
        background: rgba(59, 130, 246, 0.3);
    }

    /* ========= 加载界面 ========= */
    .loader-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: var(--bg-primary);
        backdrop-filter: blur(4px);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.3s ease;
    }
    .spinner {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: conic-gradient(
            #E74C3C 0deg 60deg,
            #F39C12 60deg 120deg,
            #2ECC71 120deg 180deg,
            #3498DB 180deg 240deg,
            #9B59B6 240deg 300deg,
            #1ABC9C 300deg 360deg
        );
        animation: spin 2s linear infinite;
        box-shadow: 0 0 10px var(--shadow);
    }
    @keyframes spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }

    /* ========= 首页卡片（通用） ========= */
    .subject-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        margin-top: 1rem;
    }
    .subject-card {
        display: block;
        background: var(--bg-card);
        border-radius: 1rem;
        padding: 1.5rem;
        text-decoration: none;
        color: var(--text-primary);
        transition: all 0.25s ease;
        border: 1px solid var(--border-color);
        box-shadow: 0 2px 4px var(--shadow);
        text-align: center;
    }
    .subject-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 20px -8px var(--shadow);
        border-color: var(--accent-primary);
    }
    .subject-icon {
        font-size: 3rem;
        display: block;
        margin-bottom: 1rem;
    }
    .subject-card h3 {
        font-size: 1.4rem;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: var(--text-primary);
    }
    .subject-card p {
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    /* ========= 科目页面布局（基础结构） ========= */
    .subject-layout {
        display: flex;
        gap: 2rem;
        margin-top: 1rem;
    }
    .subject-content {
        flex: 1;
        min-width: 0;
    }
    .sidebar {
        width: 200px;
        flex-shrink: 0;
        background: var(--bg-card);
        border-radius: 1rem;
        padding: 1.25rem;
        box-shadow: 0 4px 6px -1px var(--shadow);
        border: 1px solid var(--border-color);
    }
    .sidebar h4 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--text-primary);
        border-left: 3px solid var(--accent-primary);
        padding-left: 0.75rem;
    }
    .sidebar ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .sidebar li {
        margin-bottom: 0.75rem;
    }
    .sidebar a {
        display: block;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        padding: 0.25rem 0.5rem;
        border-radius: 0.375rem;
        transition: all 0.2s;
    }
    .sidebar a:hover {
        background: var(--border-color);
        color: var(--accent-primary);
    }

    /* ========= 文档卡片（科目页面） ========= */
    .doc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }
    .doc-card {
        background: var(--bg-card);
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px var(--shadow);
        transition: transform 0.2s, box-shadow 0.2s;
        border: 1px solid var(--border-color);
    }
    .doc-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 20px -8px var(--shadow);
    }
    .doc-card-content {
        padding: 1.25rem;
    }
    .doc-card h3 {
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
    }
    .doc-card p {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 1rem;
        line-height: 1.4;
    }
    .doc-btn {
        display: inline-block;
        background: var(--accent-primary);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: background 0.2s;
    }
    .doc-btn:hover {
        background: var(--accent-hover);
    }

    /* ========= 移动端底部导航（默认隐藏，媒体查询显示） ========= */
    .mobile-bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--bg-card);
        backdrop-filter: blur(8px);
        border-top: 1px solid var(--border-color);
        padding: 0.75rem 1rem;
        display: none;
        justify-content: space-around;
        align-items: center;
        z-index: 1000;
        box-shadow: 0 -2px 10px var(--shadow);
    }
    .mobile-bottom-nav a {
        flex: 1;
        text-align: center;
        padding: 0.5rem;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        border-radius: 2rem;
        transition: all 0.2s;
    }
    .mobile-bottom-nav a:active {
        background: var(--border-color);
        color: var(--accent-primary);
    }
</style>