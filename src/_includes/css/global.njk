<style>
    /* ========= 基础重置 ========= */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    body {
        font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        line-height: 1.5;
        padding: 2rem 1rem;
        transition: background 0.3s ease, color 0.2s ease;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

        /* ========= 导航栏（通用） ========= */
    .nav-bar {
        margin-bottom: 2rem;
        display: flex;
        justify-content: flex-start; /* 将按钮整体移到左侧 */
        align-items: center;
        gap: 0.8rem; /* 给按钮之间留出舒适的间距 */
    }
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--accent-primary);
        color: white;
        padding: 0.6rem 1.2rem;
        border-radius: 2rem;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px var(--shadow);
    }
    .back-link:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 4px 8px var(--shadow);
    }
    .theme-toggle {
        background: var(--accent-primary);
        border: none;
        color: white;
        font-size: 1.2rem;
        padding: 0.6rem 1rem;
        border-radius: 2rem;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px var(--shadow);
        /* 去掉了原本的 margin-left，现在由父级的 gap 来统一管理间距哦 */
    }
    .theme-toggle:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 4px 8px var(--shadow);
    }

    /* ========= 通用标题与副标题 ========= */
    .section-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin: 2rem 0 0.5rem 0; /* 调整外边距，拉开与上方的距离，贴近副标题 */
        padding-left: 1.2rem;
        position: relative;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        letter-spacing: 0.5px; /* 稍微增加字距，显得更大气 */
    }

    /* 使用伪元素制作渐变色圆角左边框 */
    .section-title::before {
        content: '';
        position: absolute;
        left: 0;
        top: 10%;
        bottom: 10%;
        width: 6px; /* 稍微加粗一点 */
        background: linear-gradient(to bottom, var(--accent-primary), var(--accent-hover));
        border-radius: 6px; /* 圆角让边框变得柔和 */
        box-shadow: 0 2px 4px rgba(var(--accent-primary-rgb, 37, 99, 235), 0.3); /* 增加一点点光晕 */
    }

    /* 专门为副标题增加的样式 */
    .section-desc {
        font-size: 0.95rem;
        color: var(--text-secondary);
        margin-bottom: 2rem; /* 和下方卡片拉开舒适的距离 */
        padding-left: 1.2rem; /* 和主标题保持对齐 */
        font-weight: 400;
        letter-spacing: 0.8px;
        opacity: 0.85; /* 稍微降低透明度，区分主次 */
        position: relative;
    }


        /* ========= 页脚 ========= */
    footer {
        position: fixed;
        bottom: 1.5rem; /* 固定在距离底部一点点的位置 */
        left: 50%;
        transform: translateX(-50%); /* 确保水平居中 */
        background: rgba(var(--bg-card), 0.8); /* 半透明背景 */
        border: 1px solid var(--border-color);
        border-radius: 2rem; /* 变成胶囊形状 */
        padding: 0.4rem 1.2rem;
        color: var(--text-secondary);
        font-size: 0.8rem;
        text-align: center;
        z-index: 990; /* 悬浮在内容上方 */
        box-shadow: 0 4px 10px var(--shadow);
        width: max-content; /* 宽度小一点，正好包裹住文字 */
        backdrop-filter: blur(8px); /* 毛玻璃效果，避免遮挡文字时太乱 */
        opacity: 0.75; /* 平时稍微透明，降低存在感 */
        transition: all 0.3s ease;
    }

    footer:hover {
        opacity: 1; /* 鼠标悬浮时变得清晰 */
        box-shadow: 0 6px 15px var(--shadow);
        transform: translateX(-50%) translateY(-2px); /* 轻轻上浮一点 */
    }

    footer p {
        display: inline-block; /* 让段落排在一行 */
        margin: 0 0.5rem;
    }


    /* ========= 搜索框 ========= */
    .search-container {
        margin: 1rem 0 2rem 0;
    }
    .search-box {
        width: 100%;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 2rem;
        color: var(--text-primary);
        outline: none;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px var(--shadow);
    }
    .search-box:focus {
        border-color: var(--accent-primary);
        box-shadow: 0 0 0 3px rgba(var(--accent-primary-rgb, 37, 99, 235), 0.2);
    }
    .search-box::placeholder {
        color: var(--text-secondary);
        opacity: 0.7;
    }
    mark {
        background: rgba(37, 99, 235, 0.2);
        color: inherit;
        border-radius: 0.2rem;
        padding: 0 0.1rem;
    }
    [data-theme="dark"] mark {
        background: rgba(59, 130, 246, 0.3);
    }

    /* ========= 加载界面 ========= */
    .loader-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: var(--bg-primary);
        backdrop-filter: blur(4px);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.3s ease;
    }
    .spinner {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: conic-gradient(
            #E74C3C 0deg 60deg,
            #F39C12 60deg 120deg,
            #2ECC71 120deg 180deg,
            #3498DB 180deg 240deg,
            #9B59B6 240deg 300deg,
            #1ABC9C 300deg 360deg
        );
        animation: spin 2s linear infinite;
        box-shadow: 0 0 10px var(--shadow);
    }
    @keyframes spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }

    /* ========= 首页新布局基础样式 ========= */
    .home-layout {
        display: flex;
        flex-direction: column; /* 手机端默认上下堆叠 */
        gap: 2rem;
        margin-top: 2rem;
        margin-bottom: 2rem;
        flex: 1;
    }
    .home-left, .home-right {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* 寄语卡片与名言卡片通用外观 */
    .message-card, .quote-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 1rem;
        padding: 2rem;
        box-shadow: 0 4px 6px -1px var(--shadow);
        display: flex;
        flex-direction: column;
        justify-content: center;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .message-card:hover, .quote-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 15px -3px var(--shadow);
    }

    /* 左侧寄语卡片专属定制（带一点温柔的光晕） */
    .message-card {
        text-align: center;
        font-size: 1.2rem;
        font-weight: 500;
        line-height: 1.8;
        color: var(--accent-primary);
        background: linear-gradient(135deg, rgba(var(--accent-primary-rgb), 0.08), rgba(var(--accent-primary-rgb), 0.02));
        border-color: rgba(var(--accent-primary-rgb), 0.2);
    }

    /* 右侧上方名言卡片 */
    .quote-card {
        font-size: 1.1rem;
        color: var(--text-primary);
        font-style: italic;
        padding: 1.5rem 2rem;
        border-left: 4px solid var(--accent-primary); /* 经典的左边框名言样式 */
    }
    .quote-author {
        margin-top: 0.8rem;
        font-size: 0.9rem;
        color: var(--text-secondary);
        font-style: normal;
        font-weight: 600;
        text-align: right;
    }

    /* ========= 首页卡片（通用） ========= */
    .subject-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        margin-top: 1rem;
    }
    .subject-card {
        display: block;
        background: var(--bg-card);
        border-radius: 1rem;
        padding: 1.5rem;
        text-decoration: none;
        color: var(--text-primary);
        transition: all 0.25s ease;
        border: 1px solid var(--border-color);
        box-shadow: 0 2px 4px var(--shadow);
        text-align: center;
    }
    .subject-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 20px -8px var(--shadow);
        border-color: var(--accent-primary);
    }
    .subject-icon {
        font-size: 3rem;
        display: block;
        margin-bottom: 1rem;
    }
    .subject-card h3 {
        font-size: 1.4rem;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: var(--text-primary);
    }
    .subject-card p {
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    /* ========= 科目页面布局（基础结构） ========= */
    .subject-layout {
        display: flex;
        gap: 2rem;
        margin-top: 1rem;
    }
    .subject-content {
        flex: 1;
        min-width: 0;
    }
    .sidebar {
        width: 200px;
        flex-shrink: 0;
        background: var(--bg-card);
        border-radius: 1rem;
        padding: 1.25rem;
        box-shadow: 0 4px 6px -1px var(--shadow);
        border: 1px solid var(--border-color);
    }
    .sidebar h4 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--text-primary);
        border-left: 3px solid var(--accent-primary);
        padding-left: 0.75rem;
    }
    .sidebar ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .sidebar li {
        margin-bottom: 0.75rem;
    }
    .sidebar a {
        display: block;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        padding: 0.25rem 0.5rem;
        border-radius: 0.375rem;
        transition: all 0.2s;
    }
    .sidebar a:hover {
        background: var(--border-color);
        color: var(--accent-primary);
    }

    /* ========= 文档卡片（科目页面） ========= */
    .doc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }
    .doc-card {
        background: var(--bg-card);
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px var(--shadow);
        transition: transform 0.2s, box-shadow 0.2s;
        border: 1px solid var(--border-color);
    }
    .doc-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 20px -8px var(--shadow);
    }
    .doc-card-content {
        padding: 1.25rem;
    }
    .doc-card h3 {
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
    }
    .doc-card p {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 1rem;
        line-height: 1.4;
    }
    .doc-btn {
        display: inline-block;
        background: var(--accent-primary);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: background 0.2s;
    }
    .doc-btn:hover {
        background: var(--accent-hover);
    }

    /* ========= 移动端底部导航（默认隐藏，媒体查询显示） ========= */
    .mobile-bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--bg-card);
        backdrop-filter: blur(8px);
        border-top: 1px solid var(--border-color);
        padding: 0.75rem 1rem;
        display: none;
        justify-content: space-around;
        align-items: center;
        z-index: 1000;
        box-shadow: 0 -2px 10px var(--shadow);
    }
    .mobile-bottom-nav a {
        flex: 1;
        text-align: center;
        padding: 0.5rem;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        border-radius: 2rem;
        transition: all 0.2s;
    }
    .mobile-bottom-nav a:active {
        background: var(--border-color);
        color: var(--accent-primary);
    }
</style>