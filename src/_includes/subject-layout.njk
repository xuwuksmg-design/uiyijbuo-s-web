<!DOCTYPE html>
<html lang="zh-CN">
<head>
    {% include "head.njk" %}
</head>
<body>
    <div class="container">
        {% include "header.njk" %}

        <div class="search-container">
            <input type="text" id="searchInput" class="search-box" placeholder="🔍 搜索文档标题或描述..." autocomplete="off">
        </div>

        <div class="subject-layout">
            <div class="sidebar">
                <h4>📑 快速导航</h4>
                <ul>
                    {% block sidebar_nav %}{% endblock %}
                </ul>
            </div>

            <div class="subject-content">
                {% block content %}{% endblock %}
            </div>
        </div>

                {% include "footer.njk" %}
    </div>

    <!-- 移动端悬浮折叠导航按钮与面板 -->
    <button id="mobileMenuBtn" class="mobile-menu-btn" aria-label="打开导航菜单">
        <span>☰ 导航</span>
    </button>

    <div class="mobile-menu-panel" id="mobileMenuPanel">
        <div class="mobile-menu-header">
            <span>📑 快速导航</span>
            <button id="mobileMenuCloseBtn" class="mobile-menu-close-btn" aria-label="关闭菜单">×</button>
        </div>
        <div class="mobile-menu-content">
            {% block mobile_nav %}{% endblock %}
        </div>
    </div>

    <script>
        // 平滑滚动
        function setupSmoothScroll(selector) {
            document.querySelectorAll(selector).forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    e.preventDefault();
                    const targetId = this.getAttribute('href').substring(1);
                    const targetElement = document.getElementById(targetId);
                    if (targetElement) {
                        targetElement.scrollIntoView({
                            behavior: 'smooth',
                            block: 'start'
                        });
                    }
                });
            });
        }
        setupSmoothScroll('.sidebar a');
        setupSmoothScroll('.mobile-menu-content a');

        // 移动端折叠菜单交互逻辑
        const menuBtn = document.getElementById('mobileMenuBtn');
        const closeBtn = document.getElementById('mobileMenuCloseBtn');
        const menuPanel = document.getElementById('mobileMenuPanel');

        if (menuBtn && menuPanel) {
            function openMenu() { menuPanel.classList.add('active'); }
            function closeMenu() { menuPanel.classList.remove('active'); }

            // 绑定点击事件
            menuBtn.addEventListener('click', openMenu);
            if (closeBtn) closeBtn.addEventListener('click', closeMenu);

            // 哥哥点击面板里的任意链接后，自动收起菜单
            menuPanel.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', closeMenu);
            });

            // 哥哥点击屏幕的空白处，也可以自动收起菜单哦
            document.addEventListener('click', (e) => {
                if (menuPanel.classList.contains('active') && !menuPanel.contains(e.target) && !menuBtn.contains(e.target)) {
                    closeMenu();
                }
            });
        }

        // 搜索功能（保持不变）
        function initSearch() {
            const searchInput = document.getElementById('searchInput');
            if (!searchInput) return;
            const cards = document.querySelectorAll('.doc-card');
            if (!cards.length) return;

            function removeHighlights(element) {
                element.querySelectorAll('mark').forEach(mark => {
                    const parent = mark.parentNode;
                    parent.replaceChild(document.createTextNode(mark.textContent), mark);
                    parent.normalize();
                });
            }

            function highlightKeyword(element, keyword) {
                if (!keyword) return;
                const regex = new RegExp(`(${keyword.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
                const walk = (node) => {
                    if (node.nodeType === 3) {
                        const match = node.textContent.match(regex);
                        if (match) {
                            const span = document.createElement('span');
                            let lastIndex = 0;
                            let html = '';
                            node.textContent.replace(regex, (match, p1, offset) => {
                                html += node.textContent.substring(lastIndex, offset);
                                html += `<mark>${match}</mark>`;
                                lastIndex = offset + match.length;
                            });
                            html += node.textContent.substring(lastIndex);
                            span.innerHTML = html;
                            node.parentNode.replaceChild(span, node);
                        }
                    } else if (node.nodeType === 1 && !['SCRIPT', 'STYLE', 'MARK'].includes(node.tagName)) {
                        node.childNodes.forEach(walk);
                    }
                };
                walk(element);
            }

            function filterCards() {
                const keyword = searchInput.value.trim();
                const lowerKeyword = keyword.toLowerCase();

                cards.forEach(card => {
                    const titleElem = card.querySelector('h3');
                    const descElem = card.querySelector('p');
                    const title = titleElem ? titleElem.textContent : '';
                    const desc = descElem ? descElem.textContent : '';

                    const matches = !keyword || title.toLowerCase().includes(lowerKeyword) || desc.toLowerCase().includes(lowerKeyword);

                    if (matches) {
                        card.style.display = '';
                        removeHighlights(card);
                        if (keyword) {
                            if (titleElem) highlightKeyword(titleElem, keyword);
                            if (descElem) highlightKeyword(descElem, keyword);
                        }
                    } else {
                        card.style.display = 'none';
                        removeHighlights(card);
                    }
                });
            }

            searchInput.addEventListener('input', filterCards);
        }
        document.addEventListener('DOMContentLoaded', initSearch);
    </script>
