<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>{{ title or "我的资源库" }}</title>

<!-- KaTeX 支持 -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.css">
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/contrib/auto-render.min.js"
        onload="renderMathInElement(document.body, { 
            delimiters: [
                {left: '\\[', right: '\\]', display: true},
                {left: '\\(', right: '\\)', display: false}
            ]
        });"></script>

<style>
    :root {
        --bg-primary: #f5f7fb;
        --bg-card: #ffffff;
        --text-primary: #1e293b;
        --text-secondary: #475569;
        --accent-primary: #2563eb;
        --accent-hover: #1d4ed8;
        --border-color: #e2e8f0;
        --shadow: rgba(0,0,0,0.1);
    }

    [data-theme="dark"] {
        --bg-primary: #0f172a;
        --bg-card: #1e293b;
        --text-primary: #e2e8f0;
        --text-secondary: #94a3b8;
        --accent-primary: #3b82f6;
        --accent-hover: #60a5fa;
        --border-color: #334155;
        --shadow: rgba(0,0,0,0.3);
    }

    /* 基础重置 */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    body {
        font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        line-height: 1.5;
        padding: 2rem 1rem;
        transition: background 0.3s ease, color 0.2s ease;
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
    }

    /* 导航栏右对齐 */
    .nav-bar {
        margin-bottom: 2rem;
        text-align: right;
    }
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--accent-primary);
        color: white;
        padding: 0.6rem 1.2rem;
        border-radius: 2rem;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px var(--shadow);
    }
    .back-link:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 4px 8px var(--shadow);
    }

    /* 主题切换按钮 */
    .theme-toggle {
        background: var(--accent-primary);
        border: none;
        color: white;
        font-size: 1.2rem;
        padding: 0.6rem 1rem;
        border-radius: 2rem;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px var(--shadow);
        margin-left: 0.5rem;
    }
    .theme-toggle:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 4px 8px var(--shadow);
    }

    /* 通用章节标题 */
    .section-title {
        font-size: 1.75rem;
        font-weight: 600;
        margin: 1rem 0 1.5rem 0;
        border-left: 4px solid var(--accent-primary);
        padding-left: 1rem;
    }

    /* 页脚 */
    footer {
        text-align: center;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
        color: var(--text-secondary);
        font-size: 0.875rem;
    }

    /* 首页专用样式 */
    .main-title {
        font-size: 2.5rem;
        text-align: center;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, var(--accent-primary), #7c3aed);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }
    .main-subtitle {
        text-align: center;
        color: var(--text-secondary);
        margin-bottom: 2rem;
    }
    .subject-section {
        margin: 3rem 0;
    }
    .section-heading {
        font-size: 1.8rem;
        font-weight: 600;
        border-left: 5px solid var(--accent-primary);
        padding-left: 1rem;
        margin-bottom: 0.5rem;
    }
    .section-desc {
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
    }
    /* 按钮风格的学科卡片 */
    .subject-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        margin-top: 1rem;
    }
    .subject-card {
        display: block;
        background: var(--bg-card);
        border-radius: 1rem;
        padding: 1.5rem;
        text-decoration: none;
        color: var(--text-primary);
        transition: all 0.25s ease;
        border: 1px solid var(--border-color);
        box-shadow: 0 2px 4px var(--shadow);
        text-align: center;
    }
    .subject-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 20px -8px var(--shadow);
        border-color: var(--accent-primary);
    }
    .subject-icon {
        font-size: 3rem;
        display: block;
        margin-bottom: 1rem;
    }
    .subject-card h3 {
        font-size: 1.4rem;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: var(--text-primary);
    }
    .subject-card p {
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    /* ========= 加载界面样式 ========= */
    .loader-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: var(--bg-primary);
        backdrop-filter: blur(4px);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.3s ease;
    }
    .spinner {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: conic-gradient(
            #E74C3C 0deg 60deg,
            #F39C12 60deg 120deg,
            #2ECC71 120deg 180deg,
            #3498DB 180deg 240deg,
            #9B59B6 240deg 300deg,
            #1ABC9C 300deg 360deg
        );
        animation: spin 2s linear infinite;
        box-shadow: 0 0 10px var(--shadow);
    }
    @keyframes spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }

    /* 移动端适配 */
    @media (max-width: 640px) {
        .section-title {
            font-size: 1.5rem;
        }
        .subject-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
        .subject-card {
            padding: 1.25rem;
        }
        .subject-icon {
            font-size: 2.5rem;
        }
        .subject-card h3 {
            font-size: 1.25rem;
        }
        .main-title {
            font-size: 1.8rem;
        }
        .section-heading {
            font-size: 1.5rem;
        }
    }
</style>

<!-- 公共脚本：KaTeX 加载检测 + 加载器隐藏 + 主题切换 -->
<script>
    // 立即设置主题（同步执行，在页面渲染前）
    (function() {
        let theme = localStorage.getItem('site-theme');
        if (!theme) {
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            theme = prefersDark ? 'dark' : 'light';
        }
        if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
        } else {
            document.documentElement.removeAttribute('data-theme');
        }
    })();

    window.addEventListener('load', function() {
        // KaTeX 加载检测
        var status = {
            katex: typeof katex !== 'undefined',
            renderMathInElement: typeof renderMathInElement !== 'undefined'
        };
        console.log('🔍 KaTeX 加载状态:', status);
        if (!status.katex || !status.renderMathInElement) {
            var msg = '❌ 数学公式加载失败！请检查网络后刷新页面。';
            alert(msg);
            var warning = document.createElement('div');
            warning.style.backgroundColor = '#ffebee';
            warning.style.color = '#c62828';
            warning.style.padding = '12px 16px';
            warning.style.margin = '0 auto 16px auto';
            warning.style.borderRadius = '8px';
            warning.style.textAlign = 'center';
            warning.style.fontSize = '14px';
            warning.style.maxWidth = '800px';
            warning.innerHTML = msg;
            var container = document.querySelector('.container');
            if (container && container.firstChild) {
                container.insertBefore(warning, container.firstChild);
            }
        }

        // 隐藏加载界面
        const loader = document.getElementById('loader');
        if (loader) {
            loader.style.opacity = '0';
            setTimeout(() => {
                loader.style.display = 'none';
            }, 300);
        }
    });

    // 主题切换按钮绑定
    document.addEventListener('DOMContentLoaded', function() {
        const toggleBtn = document.getElementById('theme-toggle');
        if (!toggleBtn) return;

        function applyTheme(theme) {
            const html = document.documentElement;
            if (theme === 'dark') {
                html.setAttribute('data-theme', 'dark');
            } else {
                html.removeAttribute('data-theme');
            }
            localStorage.setItem('site-theme', theme);
        }

        function toggleTheme() {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            applyTheme(isDark ? 'light' : 'dark');
        }

        toggleBtn.addEventListener('click', toggleTheme);
    });
</script>